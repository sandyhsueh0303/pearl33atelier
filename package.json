{
  "name": "pearl33atelier",
  "version": "1.0.0",
  "description": "Jewelry shop with web and inventory systems",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:public-web": "pnpm --filter public-web dev",
    "dev:inventory-admin": "pnpm --filter inventory-admin dev",
    "build:public-web": "pnpm --filter public-web build",
    "build:inventory-admin": "pnpm --filter inventory-admin build",
    "start:public-web": "pnpm --filter public-web start",
    "start:inventory-admin": "pnpm --filter inventory-admin start",
    "gen:types": "pnpm exec supabase gen types typescript --project-id xjrnyynfzbrhmotepzyl --schema public > packages/shared/types/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "gray-matter": "^4.0.3",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "supabase": "^2.76.16"
  }
}
